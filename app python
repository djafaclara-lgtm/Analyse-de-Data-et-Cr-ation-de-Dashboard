def fr(v, d=2):
    """Formate un nombre (fallback si None)."""
    if v is None or (isinstance(v, float) and math.isnan(v)):
        return "—"
    return f"{v:,.{d}f}".replace(",", "\u202f").replace(".", ",")


def detect_types(df: pd.DataFrame) -> dict[str, str]:
    """Retourne un dict {col: 'number'|'text'} avec détection heuristique."""
    types = {}
    for col in df.columns:
        converted = pd.to_numeric(df[col].dropna().astype(str)
                                  .str.replace(r"\s", "", regex=True)
                                  .str.replace(",", "."), errors="coerce")
        ratio = converted.notna().sum() / max(len(converted), 1)
        types[col] = "number" if ratio > 0.85 else "text"
    return types


def compute_stats(df: pd.DataFrame, num_cols: list[str]) -> pd.DataFrame:
    """DataFrame de statistiques descriptives pour les colonnes numériques."""
    rows = []
    for col in num_cols:
        s = df[col].dropna()
        if s.empty:
            continue
        rows.append({
            "Colonne":    col,
            "Moyenne":    s.mean(),
            "Médiane":    s.median(),
            "Écart-type": s.std(),
            "Min":        s.min(),
            "Max":        s.max(),
            "Q1":         s.quantile(0.25),
            "Q3":         s.quantile(0.75),
            "IQR":        s.quantile(0.75) - s.quantile(0.25),
            "Skewness":   s.skew(),
            "N":          len(s),
        })
    return pd.DataFrame(rows)


def detect_anomalies(df: pd.DataFrame, num_cols: list[str]) -> pd.Series:
    """Retourne un masque booléen des lignes aberrantes (méthode IQR × 1.5)."""
    mask = pd.Series(False, index=df.index)
    for col in num_cols:
        q1, q3 = df[col].quantile(0.25), df[col].quantile(0.75)
        iqr = q3 - q1
        out = (df[col] < q1 - 1.5 * iqr) | (df[col] > q3 + 1.5 * iqr)
        mask |= out.fillna(False)
    return mask


def pearson_matrix(df: pd.DataFrame, num_cols: list[str]) -> pd.DataFrame:
    """Matrice de corrélation de Pearson."""
    return df[num_cols].corr(method="pearson")


def export_excel(df: pd.DataFrame, stats: pd.DataFrame,
                 corr: pd.DataFrame, anom_df: pd.DataFrame) -> bytes:
    """Génère le fichier Excel multi-feuilles en mémoire."""
    buf = io.BytesIO()
    with pd.ExcelWriter(buf, engine="openpyxl") as writer:
        # Synthèse
        synth = pd.DataFrame({
            "Métrique": [
                "Généré le", "Lignes", "Colonnes",
                "Colonnes numériques", "Colonnes catégorielles",
                "Anomalies détectées (IQR)",
            ],
            "Valeur": [
                datetime.now().strftime("%d/%m/%Y %H:%M"),
                len(df), len(df.columns),
                len(stats), len(df.columns) - len(stats),
                len(anom_df),
            ],
        })
        synth.to_excel(writer, sheet_name="Synthèse", index=False)
        df.to_excel(writer, sheet_name="Données", index=False)
        if not stats.empty:
            stats.to_excel(writer, sheet_name="KPIs", index=False)
        if corr is not None and not corr.empty:
            corr.to_excel(writer, sheet_name="Corrélations")
        if not anom_df.empty:
            anom_df.to_excel(writer, sheet_name="Anomalies", index=False)
    return buf.getvalue()


