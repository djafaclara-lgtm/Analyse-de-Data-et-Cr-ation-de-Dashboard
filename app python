@st.cache_data(show_spinner="Chargement et analyse…")
def load_file(file_bytes: bytes, filename: str) -> pd.DataFrame:
    ext = filename.rsplit(".", 1)[-1].lower()
    buf = io.BytesIO(file_bytes)
    if ext == "csv":
        # Essai auto-detect séparateur
        sample = file_bytes[:4096].decode("utf-8", errors="replace")
        sep = "\t" if sample.count("\t") > sample.count(";") else (
              ";" if sample.count(";") > sample.count(",") else ",")
        return pd.read_csv(buf, sep=sep, on_bad_lines="skip")
    elif ext == "tsv":
        return pd.read_csv(buf, sep="\t", on_bad_lines="skip")
    else:
        return pd.read_excel(buf)


